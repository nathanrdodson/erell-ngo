---
import '../assets/css/navigation.scss'
import logo from '../assets/img/logo.svg'
import Donate from './Donate.astro'
const b = import.meta.env.BASE_URL;
---
<nav>
	<Donate />

	<div id="nav__upper">
		<div id="nav__upper__left">
			<a href="https://www.facebook.com/erellinstitute" aria-label="Erell Institute on Facebook" target="_blank" rel="noopener">
				<i class="iconoir-facebook-tag"></i>
			</a>
			<a href="https://www.instagram.com/erellinstitute" aria-label="Erell Institute on Instagram" target="_blank" rel="noopener">
				<i class="iconoir-instagram"></i>
			</a>
			<a href="https://www.researchgate.net" aria-label="Erell Institute on ResearchGate" target="_blank" rel="noopener">
				<i class="iconoir-brain-research"></i>
			</a>
		</div>

		<a href={b} class="nav__logo"><img src={logo.src} alt="Erell Institute" /></a>

		<div id="nav__upper__right">
			<a href={`${b}support/`}>Donate</a>
		</div>
		<div id="nav__secondary">
			<i class="iconoir-menu"></i>
		</div>
	</div>

	<div id="nav__middle">
		<div class="nav__dropdown">
			<a href={`${b}about/`}>About <i class="iconoir-nav-arrow-down"></i></a>
			<div class="nav__submenu">
				<a href={`${b}about/meet-the-team/`}>Meet the Team</a>
				<a href={`${b}about/newsletter-archive/`}>Newsletter Archive</a>
			</div>
		</div>
		<div class="nav__dropdown">
			<a href={`${b}education/`}>Education <i class="iconoir-nav-arrow-down"></i></a>
			<div class="nav__submenu">
				<a href={`${b}education/lizard-camp/`}>Lizard Camp</a>
				<a href={`${b}education/netp/`}>NETP</a>
			</div>
		</div>
		<div class="nav__dropdown">
			<a href={`${b}research/`}>Research <i class="iconoir-nav-arrow-down"></i></a>
			<div class="nav__submenu">
				<a href={`${b}research/social-systems/`}>Social Systems</a>
				<a href={`${b}research/movement-ecology/`}>Movement Ecology</a>
				<a href={`${b}research/italian-wall-lizards/`}>Italian Wall Lizards</a>
				<a href={`${b}research/publications/`}>Publications</a>
			</div>
		</div>
		<a href={`${b}photos/`}>Photo Gallery</a>
		<a href={`${b}support/`}>Support</a>
		<a href={`${b}contact/`}>Contact</a>
	</div>
</nav>
