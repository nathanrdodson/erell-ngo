---
import Layout from '../../layouts/Layout.astro';
const b = import.meta.env.BASE_URL;
---
<style lang="scss">
@use '../../assets/css/_theme.scss' as *;

.research-card {
	border: 1px solid $border-subtle;
	border-left: 3px solid $green-light;
	padding: 32px;
	margin-bottom: 20px;
	background: $secondary;
	transition: transform 0.22s cubic-bezier(0.4, 0, 0.2, 1),
	            box-shadow 0.22s ease,
	            border-color 0.22s ease;

	&:hover {
		transform: translateX(4px);
		box-shadow: 0 6px 24px rgba(44, 36, 22, 0.07);
		border-left-color: $green-mid;
	}

	h2 {
		font-size: 1.25rem;
		margin-bottom: 10px;
	}

	p {
		margin-bottom: 20px;
		font-size: 0.95rem;
	}

	a.learn-more {
		font-family: "indivisible", sans-serif;
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: $green-dark;
		position: relative;
		padding-bottom: 3px;

		&::after {
			content: '';
			position: absolute;
			bottom: 0;
			left: 0;
			width: 100%;
			height: 1px;
			background: $green-light;
			transition: background 0.2s ease;
		}

		&:hover {
			color: $earth-brown;

			&::after {
				background: $earth-warm;
			}
		}
	}
}
</style>
<Layout title="Research" description="Erell Institute research in behavioral ecology: movement ecology, social systems, and invasive species.">
	<main class="page-main">
		<div class="pure-g center">
			<div class="pure-u-1 pure-u-md-4-5 pure-u-lg-3-5 pure-u-xxl-1-2">
				<header class="page-header">
					<h1>Research</h1>
					<p class="page-header__lead">
						While we aim to allow our students and participants to drive the specific questions
						we ask, our general research interests fall under two main themes.
					</p>
				</header>

				<div class="research-card fade-up">
					<h2>Social Systems</h2>
					<p>
						How animals leverage group dynamics for survival and reproduction — and whether
						collaborative structures enable species to thrive in environments where solitary
						individuals might struggle.
					</p>
					<a href={`${b}research/social-systems/`} class="learn-more">Learn more!</a>
				</div>

				<div class="research-card fade-up">
					<h2>Movement Ecology</h2>
					<p>
						What factors drive movement strategies, and how these behaviors connect to
						fundamental survival needs and reproductive success.
					</p>
					<a href={`${b}research/movement-ecology/`} class="learn-more">Learn more!</a>
				</div>

				<div class="research-card fade-up">
					<h2>Italian Wall Lizards</h2>
					<a href={`${b}research/italian-wall-lizards/`} class="learn-more">Learn more!</a>
				</div>

				<div class="research-card fade-up">
					<h2>Publications</h2>
					<a href={`${b}research/publications/`} class="learn-more">View publications</a>
				</div>
			</div>
		</div>
	</main>
</Layout>
