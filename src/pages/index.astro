<script>
	const slides  = Array.from(document.querySelectorAll<HTMLElement>('.photo-carousel__slide'));
	const dots    = Array.from(document.querySelectorAll<HTMLElement>('.photo-carousel__dot'));
	const label   = document.getElementById('carousel-label');
	const labels  = ['Curiosity', 'Creativity', 'Teamwork', 'Discovery', 'Research', ''];
	let current   = 0;
	let timer: ReturnType<typeof setInterval>;

	function goTo(n: number) {
		slides[current].classList.remove('active');
		dots[current].classList.remove('active');
		current = (n + slides.length) % slides.length;
		slides[current].classList.add('active');
		dots[current].classList.add('active');
		if (label) label.textContent = labels[current];
	}

	function startTimer() {
		timer = setInterval(() => goTo(current + 1), 5000);
	}

	function resetTimer() {
		clearInterval(timer);
		startTimer();
	}

	document.querySelector('.photo-carousel__prev')?.addEventListener('click', () => { goTo(current - 1); resetTimer(); });
	document.querySelector('.photo-carousel__next')?.addEventListener('click', () => { goTo(current + 1); resetTimer(); });
	dots.forEach((dot, i) => dot.addEventListener('click', () => { goTo(i); resetTimer(); }));

	// Pause on hover
	const carousel = document.querySelector('.photo-carousel');
	carousel?.addEventListener('mouseenter', () => clearInterval(timer));
	carousel?.addEventListener('mouseleave', startTimer);

	startTimer();
</script>
