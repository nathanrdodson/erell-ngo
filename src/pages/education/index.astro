---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import imgLizardCamp from '../../assets/img/education/lezard camp.jpg';
import imgNetp       from '../../assets/img/education/netp.jpg';
import imgUgResearch from '../../assets/img/education/ug research experiences.jpg';
const b = import.meta.env.BASE_URL;
---
<style lang="scss">
@use '../../assets/css/_theme.scss' as *;
@use '../../assets/css/_mixins.scss' as *;

.programs-grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: 24px;
}

.program-card {
	border: 1px solid $border-subtle;
	background: $secondary;
	overflow: hidden;
	display: grid;
	grid-template-columns: 280px 1fr;
	transition: transform 0.22s cubic-bezier(0.4, 0, 0.2, 1),
	            box-shadow 0.22s ease,
	            border-color 0.22s ease;

	@include respond-to('small-mx') {
		grid-template-columns: 1fr;
	}

	&:hover {
		transform: translateY(-4px);
		box-shadow: 0 12px 36px rgba(44, 36, 22, 0.09);
		border-color: $green-light;
	}

	&__photo {
		width: 100%;
		height: 100%;
		min-height: 220px;
		object-fit: cover;
		object-position: center;
		display: block;
		transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
	}

	&:hover &__photo {
		transform: scale(1.03);
	}

	&__photo-wrap {
		overflow: hidden;

		@include respond-to('small-mx') {
			height: 200px;
		}
	}

	&__body {
		padding: 28px 32px 32px;
		border-left: 3px solid $green-light;

		@include respond-to('small-mx') {
			border-left: none;
			border-top: 3px solid $green-light;
		}
	}

	h2 {
		font-size: 1.25rem;
		margin-bottom: 10px;
	}

	p {
		margin-bottom: 20px;
		font-size: 0.95rem;
	}

	a.learn-more {
		font-family: "indivisible", sans-serif;
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: $green-dark;
		position: relative;
		padding-bottom: 3px;

		&::after {
			content: '';
			position: absolute;
			bottom: 0;
			left: 0;
			width: 100%;
			height: 1px;
			background: $green-light;
			transition: background 0.2s ease;
		}

		&:hover {
			color: $earth-brown;
			&::after { background: $earth-warm; }
		}
	}
}
</style>
<Layout title="Education" description="Erell Institute education programs: Lizard Camp and NETP provide hands-on research experiences for students from all backgrounds.">
	<main class="page-main">
		<div class="pure-g center">
			<div class="pure-u-1 pure-u-md-4-5 pure-u-lg-3-5 pure-u-xxl-1-2">
				<header class="page-header">
					<h1>Education</h1>
					<p class="page-header__lead">
						We believe the best way to teach people how to be a scientist is to bring them
						into the field and let them explore and learn how to be curious and ask questions
						inspired by the nature around them!
					</p>
				</header>

				<div class="programs-grid">

					<div class="program-card fade-up">
						<div class="program-card__photo-wrap">
							<Image src={imgLizardCamp} alt="Lizard Camp field research" class="program-card__photo" />
						</div>
						<div class="program-card__body">
							<h2>Lizard Camp</h2>
							<p>
								Using hands on learning in desert ecosystems to teach students how to be a scientist!
							</p>
							<a href={`${b}education/lizard-camp/`} class="learn-more">Learn more about Lizard Camp</a>
						</div>
					</div>

					<div class="program-card fade-up">
						<div class="program-card__photo-wrap">
							<Image src={imgNetp} alt="NETP — Naturalist-Ecologist Training Program" class="program-card__photo" />
						</div>
						<div class="program-card__body">
							<h2>Naturalist-Ecologist Training Program (NETP)</h2>
							<p>
								Developing curiosity and creativity in young researchers while they determine their next steps in science.
							</p>
							<a href={`${b}education/netp/`} class="learn-more">Learn more about NETP</a>
						</div>
					</div>

					<div class="program-card fade-up">
						<div class="program-card__photo-wrap">
							<Image src={imgUgResearch} alt="Undergraduate research experiences" class="program-card__photo" />
						</div>
						<div class="program-card__body">
							<h2>Undergraduate Research Experiences</h2>
							<p>
								Learn more about our past projects and find out about upcoming opportunities!
							</p>
							<a href={`${b}education/netp/`} class="learn-more">Learn more about undergrad research</a>
						</div>
					</div>

				</div>
			</div>
		</div>
	</main>
</Layout>
